# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔮 Sanskrit Grammar – Words & Grammar Guidance App
# Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenRouter API Key (REQUIRED)
# Get your key from: https://openrouter.ai/keys
# This key is used for AI Chat, Vision Analysis, and Translation
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Base URL
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# AI Model for Reasoning / Sanskrit Text Processing
VITE_AI_REASONING_MODEL=liquid/lfm-2.5-1.2b-thinking:free

# AI Model for Vision / Image Analysis
VITE_AI_VISION_MODEL=allenai/molmo-2-8b:free

# App Info
VITE_APP_NAME=Sanskrit Grammar
VITE_APP_VERSION=1.0.0
